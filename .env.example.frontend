# Frontend (Next.js) — copy to .env.local for local dev
# On Vercel: set these in Project Settings → Environment Variables

# Vendure Shop GraphQL endpoint (optional — frontend falls back to offline products)
NEXT_PUBLIC_VENDURE_SHOP_API=https://your-vendure-domain.com/shop-api

# CMS public API base URL (optional — frontend falls back to local mock posts)
NEXT_PUBLIC_CMS_BASE_URL=https://your-cms-domain.com

# WhatsApp click-to-chat URL (used by ResultPaywall + Shop CTA)
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/8615000000000

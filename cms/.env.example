# --- CMS environment ---
# Database
DATABASE_URL="postgresql://lingyun:lingyun@localhost:5432/lingyun_cms?schema=public"

# Auth — change in production!
AUTH_SECRET="please-change-me-to-a-long-random-string"

# Public site origin allowed to call this API
PUBLIC_ALLOWED_ORIGIN="http://localhost:3000"

# Seed admin
SEED_ADMIN_EMAIL="admin@lingyun.local"
SEED_ADMIN_PASSWORD="admin123456"

# Where to store uploaded media (relative to cms/)
UPLOAD_DIR="public/uploads"
PUBLIC_UPLOAD_BASE="/uploads"

# AI assistant (OpenAI-compatible). Leave AI_API_KEY blank to use the local stub.
AI_BASE_URL="https://api.openai.com/v1"
AI_API_KEY=""
AI_MODEL="gpt-4o-mini"

DB_PASSWORD=postgres
DB_SCHEMA=public

# Superadmin (created on first run)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin

# Admin UI / shop URLs (CORS)
SHOP_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:3002
